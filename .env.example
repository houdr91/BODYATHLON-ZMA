# .env.example
# Copia este archivo como .env.local y rellena los valores reales
# Este archivo SÍ va al repositorio — NUNCA pongas valores reales aquí

# Base de datos
# Desarrollo local (SQLite — ruta relativa al directorio prisma/):
DATABASE_URL="file:./dev.db"
# Producción (PostgreSQL en Vercel + Neon/Supabase):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NextAuth
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET=""
# NextAuth v5 también lee AUTH_SECRET — usa EXACTAMENTE el mismo valor que NEXTAUTH_SECRET
AUTH_SECRET=""
# Desarrollo local:
NEXTAUTH_URL="http://localhost:3000"
# Producción (reemplaza con tu URL de Vercel):
# NEXTAUTH_URL="https://bodyathlon-zma.vercel.app"

# Node environment
NODE_ENV="development"

# IMPORTANTE: Nunca uses NEXT_PUBLIC_ para secrets — son visibles en el navegador
